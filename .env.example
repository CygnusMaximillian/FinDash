# Copy to .env and fill in your values
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Financial Dashboard
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=8h

# Bcrypt
BCRYPT_ROUNDS=12

# Polling interval bounds (ms) – used in docs / client guidance
POLL_MIN_MS=10000
POLL_MAX_MS=30000
